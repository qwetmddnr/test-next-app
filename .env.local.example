# Site URL (sitemap, robots, OG metadata에 사용)
# 배포 도메인 결정 후 채우기 (예: https://today-na.com)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Anthropic Claude API (서버 전용 — NEXT_PUBLIC 접두사 금지)
ANTHROPIC_API_KEY=sk-ant-...

# Google AdSense (승인 후 발급되는 ca-pub-XXXXXXXXXXXXXXXX 형식)
# 비워두면 광고 자리는 placeholder로 표시됩니다.
NEXT_PUBLIC_ADSENSE_CLIENT=

# Google Analytics 4 (G-XXXXXXXXXX 형식)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Microsoft Clarity (프로젝트 ID)
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# Vercel Cron 인증용 시크릿 (랜덤 문자열, 32자 이상 권장)
# 매일 자정 일일 운세 ai_cache prewarm cron이 이 값을 Authorization 헤더로 사용
CRON_SECRET=

# Kakao JavaScript SDK (결과 페이지 카카오 공유)
# Kakao Developers > 내 애플리케이션 > 앱 키 > JavaScript 키
# Web 플랫폼에 사용 도메인(ohna.today + 로컬 dev 포트) 등록 필수, 카카오 공유 기능 활성화 필요
# 비워두면 공유 시트에서 카카오 옵션이 자동 hide됩니다.
NEXT_PUBLIC_KAKAO_JS_KEY=
