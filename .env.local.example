# Site URL (sitemap, robots, OG metadata에 사용)
# 배포 도메인 결정 후 채우기 (예: https://today-na.com)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Anthropic Claude API (서버 전용 — NEXT_PUBLIC 접두사 금지)
ANTHROPIC_API_KEY=sk-ant-...

# Google AdSense (승인 후 발급되는 ca-pub-XXXXXXXXXXXXXXXX 형식)
# 비워두면 광고 자리는 placeholder로 표시됩니다.
NEXT_PUBLIC_ADSENSE_CLIENT=

# Google Analytics 4 (G-XXXXXXXXXX 형식)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Microsoft Clarity (프로젝트 ID)
NEXT_PUBLIC_CLARITY_PROJECT_ID=
